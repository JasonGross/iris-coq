"test_impl"
     : string
1 goal
  
  PROP : bi
  Sbi0 : Sbi PROP
  A : ofe
  x, y, z : A
  ============================
  ∀ n : nat, x ≡{n}≡ y → y ≡{n}≡ z → x ≡{n}≡ z
"test_impl_impl_and"
     : string
1 goal
  
  PROP : bi
  Sbi0 : Sbi PROP
  A : ofe
  x, y, z : A
  ============================
  ∀ n : nat, x ≡{n}≡ y → y ≡{n}≡ z → x ≡{n}≡ z ∧ z ≡{n}≡ x
