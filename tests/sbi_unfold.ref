"test_wand_iff_exist"
     : string
1 goal
  
  PROP : bi
  Sbi0 : Sbi PROP
  A : ofe
  x, z : A
  ============================
  ∀ n : nat,
    match n with
    | 0 => True
    | S n' => x ≡{n'}≡ z
    end
    ↔ ∃ x0 : A,
        match n with
        | 0 => True
        | S n' => x ≡{n'}≡ x0 ∧ x0 ≡{n'}≡ z
        end
"test_exist_impl"
     : string
1 goal
  
  PROP : bi
  Sbi0 : Sbi PROP
  A : ofe
  x, z : A
  ============================
  ∀ n : nat,
    x ≡{n}≡ z → ∃ x0 : A, ∀ n' : nat, n' ≤ n → x ≡{n'}≡ x0 → x0 ≡{n'}≡ z
"test_forall_impl"
     : string
1 goal
  
  PROP : bi
  Sbi0 : Sbi PROP
  A : ofe
  x, z : A
  ============================
  ∀ n : nat,
    (∀ (x0 : A) (n' : nat), n' ≤ n → x ≡{n'}≡ x0 → x0 ≡{n'}≡ z) → x ≡{n}≡ z
